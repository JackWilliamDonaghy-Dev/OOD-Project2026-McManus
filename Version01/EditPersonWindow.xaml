<Window x:Class="Version01.EditPersonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Version01"
        mc:Ignorable="d"
        Title="EditPersonWindow" Height="400" Width="300"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="21*"/>
            <RowDefinition Height="43*"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="20,20,20,20">
            <Grid>
                <Label Content="Name -" HorizontalAlignment="Left" FontWeight="Bold"></Label>
                <TextBox x:Name="txtbxName" Margin="55,0,0,0"></TextBox>
            </Grid>
            <Grid>
                <Label Content="Last Contact -" HorizontalAlignment="Left" FontWeight="Bold"></Label>
                <TextBlock x:Name="txtblckLastContact" Margin="94,0,0,0"></TextBlock>
            </Grid>
        </StackPanel>
        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <Label Content="Messages"  HorizontalAlignment="Left" VerticalAlignment="Top" Grid.Row="1" Margin="40,0,0,0"/>
            <ListBox x:Name="lsbxMessages"></ListBox>
            <Button Content="New Message" Width="150" Click="btnAddMessage_Click"/>
        </StackPanel>
        <Button Content="Close Window" HorizontalAlignment="Left" Click="btnClose_Click" VerticalAlignment="Bottom" Margin="20,0,0,20" Width="140" Style="{DynamicResource MaterialDesignRaisedSecondaryButton}" Grid.Row="1" Height="32"/>
        <Button Content="Delete" HorizontalAlignment="Right" Click="btnDelete_Click" VerticalAlignment="Bottom" Margin="0,0,20,20" Width="100" Style="{DynamicResource MaterialDesignRaisedLightButton}" Grid.Row="1" Height="32"/>


    </Grid>
</Window>
